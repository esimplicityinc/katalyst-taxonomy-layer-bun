# Generated by: kata tax cicd render gha-ci
# Taxonomy: {{ system }}.{{ sub_system }}.{{ stack }}
name: "{{ system }}-{{ sub_system }}-{{ stack }}-ci"

on:
  push:
    branches: [main]
    paths:
      - "app/**"
      - "k8s/**"
      - ".github/workflows/**"
  pull_request:
    branches: [main]
  workflow_dispatch:

jobs:
  # -- CI Stage ------------------------------------------------
  app-bun-ci:
    name: "🥟 App Bun Layer :: CI"
    uses: ./.github/workflows/.template-app-bun-ci.yaml
    with:
      system: "{{ system }}"
      sub_system: "{{ sub_system }}"
      stack: "{{ stack }}"
      environment: "{{ environment }}"
      aws_role_arn: "n/a"
      aws_region: "us-east-1"

  # -- Security Scans -----------------------------------------
  app-security-scan:
    name: "🔒 App Security :: Semgrep"
    uses: ./.github/workflows/.template-app-bun-security.yaml
    with:
      system: "{{ system }}"
      sub_system: "{{ sub_system }}"
      stack: "{{ stack }}"
      environment: "{{ environment }}"

  docker-image-scan:
    name: "🐳 Docker Image :: Trivy"
    uses: ./.github/workflows/.template-docker-scan.yaml
    with:
      system: "{{ system }}"
      sub_system: "{{ sub_system }}"
      stack: "{{ stack }}"
      environment: "{{ environment }}"
