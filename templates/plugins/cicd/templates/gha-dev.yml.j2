# Generated by: kata tax cicd render gha-dev
# Taxonomy: {{ system }}.{{ sub_system }}.{{ stack }}
name: "{{ system }}-{{ sub_system }}-{{ stack }}-{{ environment }}"

on:
  push:
    branches: [main]
    paths:
      - "app/**"
      - "k8s/**"
      - ".github/workflows/**"
  workflow_dispatch:

permissions:
  id-token: write
  contents: read

jobs:
  # -- CD Stage ------------------------------------------------
  app-bun-cd:
    name: "🥟 App Bun Layer :: CD"
    uses: ./.github/workflows/.template-app-bun-cd.yaml
    with:
      system: "{{ system }}"
      sub_system: "{{ sub_system }}"
      stack: "{{ stack }}"
      environment: "{{ environment }}"
      aws_role_arn: "{{ aws_role_arn }}"
      aws_region: "{{ aws_region }}"
    secrets: inherit

  # -- Post Stage ----------------------------------------------
  app-bun-post:
    name: "🥟 App Bun Layer :: POST"
    needs: [app-bun-cd]
    uses: ./.github/workflows/.template-app-bun-post.yaml
    with:
      system: "{{ system }}"
      sub_system: "{{ sub_system }}"
      stack: "{{ stack }}"
      environment: "{{ environment }}"
      aws_role_arn: "{{ aws_role_arn }}"
      aws_region: "{{ aws_region }}"
      eks_cluster_arn: "{{ eks_cluster_arn | default('') }}"
      argo_app: "{{ argo_app | default('') }}"
      health_url: "{{ health_url | default('') }}"
