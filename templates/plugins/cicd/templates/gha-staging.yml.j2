# Generated by: kata tax cicd render gha-staging
# Taxonomy: {{ system }}.{{ sub_system }}.{{ stack }}
name: "{{ system }}-{{ sub_system }}-{{ stack }}-{{ environment }}"

on:
  workflow_dispatch:
    inputs:
      image_tag:
        description: "Image tag to promote to staging"
        required: true
        type: string

permissions:
  id-token: write
  contents: read

jobs:
  # -- CD Stage ------------------------------------------------
  app-bun-cd:
    name: "🥟 App Bun Layer :: CD (Staging)"
    uses: ./.github/workflows/.template-app-bun-cd.yaml
    with:
      system: "{{ system }}"
      sub_system: "{{ sub_system }}"
      stack: "{{ stack }}"
      environment: "{{ environment }}"
      aws_role_arn: "{{ aws_role_arn }}"
      aws_region: "{{ aws_region }}"
    secrets: inherit

  # -- Post Stage ----------------------------------------------
  app-bun-post:
    name: "🥟 App Bun Layer :: POST (Staging)"
    needs: [app-bun-cd]
    uses: ./.github/workflows/.template-app-bun-post.yaml
    with:
      system: "{{ system }}"
      sub_system: "{{ sub_system }}"
      stack: "{{ stack }}"
      environment: "{{ environment }}"
      aws_role_arn: "{{ aws_role_arn }}"
      aws_region: "{{ aws_region }}"
      eks_cluster_arn: "{{ eks_cluster_arn | default('') }}"
      argo_app: "{{ argo_app | default('') }}"
      health_url: "{{ health_url | default('') }}"
