{{ job_id | default('security_scan') }}:
  name: "{{ job_name | default('🔒 Security Scan') }}"
  uses: "{{ workflow_path }}"
  {% if needs %}
  needs:
  {% for need in needs %}
    - {{ need }}
  {% endfor %}
  {% endif %}
  with:
    system: "{{ system }}"
    sub_system: "{{ sub_system }}"
    stack: "{{ stack }}"
    environment: "{{ environment }}"
